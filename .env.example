# Django
DEBUG=True
SECRET_KEY=change-me-in-production-use-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost,care-u-9c6b.onrender.com
# Use development locally; production on Render/hosting
DJANGO_SETTINGS_MODULE=config.settings.development

# Database — SQLite by default for local dev (no PostgreSQL required).
# For schema-isolated multi-tenancy in production, set DB_ENGINE=postgres and DATABASE_URL.
DB_ENGINE=sqlite
SQLITE_DB_NAME=db.sqlite3

# PostgreSQL (production / multi-tenant schema isolation)
# DATABASE_URL=postgres://gph:gph_secret@localhost:5432/gph_erp
# DB_ENGINE=postgres
# DB_NAME=gph_erp
# DB_USER=gph
# DB_PASSWORD=gph_secret
# DB_HOST=localhost
# DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Multi-tenancy
BASE_DOMAIN=localhost
PLATFORM_NAME=CARE-U
TRIAL_DAYS=14
TENANT_USE_SUBFOLDER=true

# Email (console backend used if not set)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@care-u.com

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS S3 (optional - local storage used if not set)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1

# Stripe (placeholder)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry (optional)
SENTRY_DSN=

