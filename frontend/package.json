{
  "name": "gph-erp-frontend",
  "version": "1.0.0",
  "scripts": {
    "prebuild:css": "npm install --no-audit --no-fund",
    "build:css": "node ./node_modules/tailwindcss/lib/cli.js -i ../static/src/input.css -o ../static/css/output.css --minify",
    "prewatch:css": "npm install --no-audit --no-fund",
    "watch:css": "node ./node_modules/tailwindcss/lib/cli.js -i ../static/src/input.css -o ../static/css/output.css --watch",
    "setup": "npm install --no-audit --no-fund && npm run build:css"
  },
  "devDependencies": {
    "daisyui": "^4.12.14",
    "tailwindcss": "^3.4.15"
  }
}
